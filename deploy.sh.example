```bash
#!/bin/bash

# Deploy script dummy untuk Camp Bebas Riba Indonesia
# Tested di Ubuntu/Debian VPS

set -e

echo "=== Camp Bebas Riba - Deploy Script Dummy ==="
echo ""

# ==========================
# DUMMY CONFIG
# Silakan ubah sesuai kebutuhan
# ==========================
DOMAIN="campbebasriba.com"
MYSQL_PASS="passwordrootdummy"
JWT_SECRET="dummy_jwt_secret_camp_bebas_riba_2026_panjang"
DB_NAME="campbebasriba"
APP_PORT="4000"

ADMIN_EMAIL="cbradmin2026@gmail.com"
ADMIN_PASSWORD="Admin@CBR2026"

APP_DIR="/var/www/cbr"

echo "Domain       : $DOMAIN"
echo "Database     : $DB_NAME"
echo "Backend Port : $APP_PORT"
echo ""

# Install dependencies
echo ">>> Installing Node.js, Nginx, MySQL..."
apt update && apt upgrade -y
apt install -y curl nginx mysql-server certbot python3-certbot-nginx

# Install Node.js 18
echo ""
echo ">>> Installing Node.js 18..."
curl -fsSL https://deb.nodesource.com/setup_18.x | bash -
apt install -y nodejs

# Install PM2
echo ""
echo ">>> Installing PM2..."
npm install -g pm2

# Pastikan folder project
echo ""
echo ">>> Preparing project directory..."
mkdir -p "$APP_DIR"
cd "$APP_DIR"

# Setup MySQL
echo ""
echo ">>> Setting up MySQL database..."
mysql -u root -p"$MYSQL_PASS" -e "CREATE DATABASE IF NOT EXISTS ${DB_NAME};"

# Create .env file
echo ""
echo ">>> Creating .env file..."
cat > .env << EOF
DATABASE_URL="mysql://root:${MYSQL_PASS}@localhost:3306/${DB_NAME}"
JWT_SECRET="${JWT_SECRET}"
PORT=${APP_PORT}
VITE_API_URL="http://${DOMAIN}/api"

ADMIN_EMAIL="${ADMIN_EMAIL}"
ADMIN_PASSWORD="${ADMIN_PASSWORD}"
EOF

# Install project dependencies
echo ""
echo ">>> Installing project dependencies..."
npm install

# Generate Prisma client
echo ""
echo ">>> Generating Prisma client..."
npx prisma generate

# Run migrations
echo ""
echo ">>> Running database migrations..."
npx prisma migrate deploy

# Seed admin user
echo ""
echo ">>> Seeding admin user..."
npx tsx server/seed-admin.ts

# Build frontend
echo ""
echo ">>> Building frontend..."
npm run build

# Setup Nginx
echo ""
echo ">>> Configuring Nginx..."
cat > /etc/nginx/sites-available/cbr << EOF
server {
    listen 80;
    server_name ${DOMAIN};

    root ${APP_DIR}/dist;
    index index.html;

    location / {
        try_files \$uri \$uri/ /index.html;
    }

    location /api {
        proxy_pass http://localhost:${APP_PORT};
        proxy_http_version 1.1;

        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host \$host;
        proxy_cache_bypass \$http_upgrade;
    }
}
EOF

ln -sf /etc/nginx/sites-available/cbr /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default

nginx -t
systemctl reload nginx

# Start backend with PM2
echo ""
echo ">>> Starting backend server..."
pm2 delete cbr-api 2>/dev/null || true
pm2 start server/index.ts --name cbr-api --interpreter tsx
pm2 save

# Setup PM2 startup
echo ""
echo ">>> Setting up PM2 startup..."
pm2 startup systemd -u root --hp /root || true

# Setup SSL optional
echo ""
read -p "Setup SSL dengan Certbot? (y/n): " SETUP_SSL

if [ "$SETUP_SSL" = "y" ]; then
    certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos -m admin@"$DOMAIN"
fi

echo ""
echo "=== Deploy Selesai! ==="
echo ""
echo "URL Website : http://${DOMAIN}"
echo "API URL     : http://${DOMAIN}/api"
echo ""
echo "Cek Backend:"
echo "  pm2 logs cbr-api"
echo "  pm2 status"
echo "  pm2 restart cbr-api"
echo ""
echo "Admin Login Dummy:"
echo "  Email    : ${ADMIN_EMAIL}"
echo "  Password : ${ADMIN_PASSWORD}"
echo ""
```
